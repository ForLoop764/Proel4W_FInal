@{
    ViewData["Title"] = "Home Page";
}

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet">

<style>
    :root {
        --ink: #111008;
        --sand: #f5efe6;
        --warm: #e8ddd0;
        --roast: #2c1a0e;
        --amber: #b85c1a;
        --gold: #d4943a;
        --mist: #f9f5f0;
        --rule: rgba(44,26,14,.1);
    }

    *, *::before, *::after {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    html {
        scroll-behavior: smooth;
    }

    body {
        font-family: 'Outfit', sans-serif;
        background: var(--sand);
        color: var(--ink);
        overflow-x: hidden;
        -webkit-font-smoothing: antialiased;
    }

    /* ── RESET BOOTSTRAP CONTAINER ── */
    .container, .container-fluid,
    .container-lg, .container-md,
    .container-sm, .container-xl {
        max-width: 100% !important;
        padding: 0 !important;
        margin: 0 !important;
    }

    .page-wrap {
        width: 100vw;
        position: relative;
        left: 50%;
        margin-left: -50vw;
    }

    /* ══════════════════════════════
           NAV
        ══════════════════════════════ */
    .nav {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 200;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 4rem;
        height: 64px;
        background: rgba(245,239,230,.92);
        backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--rule);
    }

    .nav-logo {
        font-family: 'Playfair Display', serif;
        font-size: 1.35rem;
        font-weight: 900;
        color: var(--roast);
        letter-spacing: -.5px;
        text-decoration: none;
    }

        .nav-logo em {
            font-style: italic;
            color: var(--amber);
        }

    .nav-links {
        display: flex;
        align-items: center;
        gap: 2.5rem;
        list-style: none;
    }

        .nav-links a {
            font-size: .85rem;
            font-weight: 500;
            color: var(--roast);
            text-decoration: none;
            letter-spacing: .3px;
            opacity: .65;
            transition: opacity .2s;
        }

            .nav-links a:hover {
                opacity: 1;
            }

    .nav-cta {
        font-size: .82rem;
        font-weight: 600;
        color: #fff !important;
        opacity: 1 !important;
        background: var(--roast);
        padding: .5rem 1.4rem;
        border-radius: 4px;
        transition: background .2s !important;
    }

        .nav-cta:hover {
            background: var(--amber) !important;
        }

    /* ══════════════════════════════
           HERO
        ══════════════════════════════ */
    .hero {
        min-height: 100vh;
        padding-top: 64px;
        display: grid;
        grid-template-columns: 55% 45%;
    }

    /* LEFT */
    .hero-left {
        background: var(--roast);
        padding: 7rem 5rem 5rem;
        display: flex;
        flex-direction: column;
        justify-content: center;
        position: relative;
        overflow: hidden;
    }

        .hero-left::after {
            content: '';
            position: absolute;
            inset: 0;
            background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.02'%3E%3Ccircle cx='30' cy='30' r='1'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
            pointer-events: none;
        }

    .hero-eyebrow {
        display: flex;
        align-items: center;
        gap: .6rem;
        font-size: .72rem;
        font-weight: 600;
        letter-spacing: 2.5px;
        text-transform: uppercase;
        color: var(--gold);
        margin-bottom: 2rem;
    }

        .hero-eyebrow::before {
            content: '';
            display: block;
            width: 28px;
            height: 1px;
            background: var(--gold);
        }

    .hero-h1 {
        font-family: 'Playfair Display', serif;
        font-size: clamp(3.2rem, 5vw, 5.2rem);
        font-weight: 900;
        line-height: 1.02;
        color: var(--mist);
        margin-bottom: 1.8rem;
    }

        .hero-h1 span {
            font-style: italic;
            color: var(--gold);
        }

    .hero-p {
        font-size: 1rem;
        line-height: 1.75;
        color: rgba(249,245,240,.55);
        max-width: 380px;
        margin-bottom: 3rem;
        font-weight: 300;
    }

    .hero-actions {
        display: flex;
        align-items: center;
        gap: 1.2rem;
    }

    .btn {
        display: inline-flex;
        align-items: center;
        gap: .5rem;
        font-family: 'Outfit', sans-serif;
        font-size: .88rem;
        font-weight: 600;
        border-radius: 4px;
        padding: .85rem 1.8rem;
        cursor: pointer;
        text-decoration: none;
        transition: all .2s;
        border: none;
    }

    .btn-amber {
        background: var(--amber);
        color: #fff;
    }

        .btn-amber:hover {
            background: #c8651f;
            color: #fff;
            transform: translateY(-1px);
            box-shadow: 0 6px 20px rgba(184,92,26,.35);
        }

    .btn-ghost {
        background: transparent;
        color: rgba(249,245,240,.6);
        border: 1px solid rgba(249,245,240,.18);
        padding: .85rem 1.6rem;
    }

        .btn-ghost:hover {
            border-color: rgba(249,245,240,.5);
            color: var(--mist);
        }

    .hero-metrics {
        display: flex;
        gap: 0;
        margin-top: 4rem;
        padding-top: 2.5rem;
        border-top: 1px solid rgba(249,245,240,.08);
    }

    .metric {
        flex: 1;
        padding-right: 2rem;
        border-right: 1px solid rgba(249,245,240,.08);
    }

        .metric:last-child {
            border-right: none;
            padding-right: 0;
            padding-left: 2rem;
        }

        .metric:not(:first-child):not(:last-child) {
            padding-left: 2rem;
        }

    .metric-val {
        font-family: 'Playfair Display', serif;
        font-size: 2rem;
        font-weight: 700;
        color: var(--gold);
        line-height: 1;
    }

    .metric-lbl {
        font-size: .72rem;
        font-weight: 500;
        letter-spacing: 1px;
        text-transform: uppercase;
        color: rgba(249,245,240,.35);
        margin-top: .4rem;
    }

    /* RIGHT */
    .hero-right {
        background: var(--mist);
        position: relative;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        justify-content: flex-end;
    }

    .hero-img-block {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .hero-coffee-graphic {
        font-size: 11rem;
        animation: riseUp 3.5s ease-in-out infinite;
        filter: drop-shadow(0 40px 60px rgba(44,26,14,.18));
        line-height: 1;
    }

   

    .hero-chips {
        position: absolute;
        inset: 0;
        pointer-events: none;
    }

    .chip {
        position: absolute;
        background: #fff;
        border: 1px solid var(--rule);
        border-radius: 6px;
        padding: .55rem 1rem;
        font-size: .78rem;
        font-weight: 600;
        color: var(--roast);
        box-shadow: 0 2px 12px rgba(44,26,14,.07);
        white-space: nowrap;
        animation: chipFloat 5s ease-in-out infinite;
    }

    .chip-1 {
        top: 18%;
        left: 8%;
        animation-delay: 0s;
    }

    .chip-2 {
        top: 14%;
        right: 6%;
        animation-delay: 1.2s;
    }

    .chip-3 {
        bottom: 30%;
        left: 6%;
        animation-delay: 2.4s;
    }

    .chip-4 {
        bottom: 24%;
        right: 8%;
        animation-delay: .6s;
    }

    

    .hero-card {
        position: relative;
        z-index: 2;
        margin: 2rem;
        background: #fff;
        border-radius: 10px;
        padding: 1.4rem 1.8rem;
        border: 1px solid var(--rule);
        box-shadow: 0 4px 24px rgba(44,26,14,.07);
        display: flex;
        align-items: center;
        gap: 1.2rem;
    }

    .hero-card-icon {
        width: 44px;
        height: 44px;
        background: var(--amber);
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.4rem;
        flex-shrink: 0;
    }

    .hero-card-text {
        flex: 1;
    }

    .hero-card-title {
        font-size: .88rem;
        font-weight: 600;
        color: var(--roast);
    }

    .hero-card-sub {
        font-size: .76rem;
        color: #9a8878;
        margin-top: .2rem;
    }

    .hero-card-badge {
        font-size: .7rem;
        font-weight: 700;
        background: #eef7f0;
        color: #2a7a4a;
        padding: .25rem .65rem;
        border-radius: 20px;
    }

    /* ══════════════════════════════
           TICKER / MARQUEE
        ══════════════════════════════ */
    .ticker {
        background: var(--amber);
        overflow: hidden;
        padding: .7rem 0;
        white-space: nowrap;
    }

    .ticker-inner {
        display: inline-flex;
        gap: 3rem;
        animation: ticker 22s linear infinite;
    }

    .ticker-item {
        font-size: .78rem;
        font-weight: 600;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        color: #fff;
        display: inline-flex;
        align-items: center;
        gap: .8rem;
    }

        .ticker-item::after {
            content: '·';
            opacity: .5;
        }

    

    /* ══════════════════════════════
           MENU SECTION
        ══════════════════════════════ */
    .section {
        padding: 6rem 5rem;
    }

    .section-head {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        margin-bottom: 3.5rem;
        padding-bottom: 2rem;
        border-bottom: 1px solid var(--rule);
    }

    .section-label {
        font-size: .7rem;
        font-weight: 600;
        letter-spacing: 3px;
        text-transform: uppercase;
        color: var(--amber);
        margin-bottom: .6rem;
    }

    .section-title {
        font-family: 'Playfair Display', serif;
        font-size: clamp(2rem, 3.5vw, 3rem);
        font-weight: 900;
        color: var(--roast);
        line-height: 1.1;
    }

    .section-link {
        font-size: .82rem;
        font-weight: 600;
        color: var(--amber);
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: .4rem;
        padding-bottom: 2px;
        border-bottom: 1px solid transparent;
        transition: border-color .2s;
    }

        .section-link:hover {
            border-color: var(--amber);
        }

    .menu-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 1.5rem;
    }

    .menu-card {
        background: #fff;
        border: 1px solid var(--rule);
        border-radius: 10px;
        padding: 2rem 1.6rem 1.6rem;
        position: relative;
        overflow: hidden;
        transition: box-shadow .25s, transform .25s;
        cursor: default;
    }

        .menu-card:hover {
            box-shadow: 0 16px 48px rgba(44,26,14,.1);
            transform: translateY(-4px);
        }

    .menu-card-tag {
        position: absolute;
        top: 1.2rem;
        right: 1.2rem;
        font-size: .62rem;
        font-weight: 700;
        letter-spacing: 1px;
        text-transform: uppercase;
        color: var(--amber);
        background: rgba(184,92,26,.08);
        padding: .2rem .6rem;
        border-radius: 3px;
    }

    .menu-card-emoji {
        font-size: 2.8rem;
        margin-bottom: 1.2rem;
        display: block;
    }

    .menu-card-name {
        font-family: 'Playfair Display', serif;
        font-size: 1.1rem;
        font-weight: 700;
        color: var(--roast);
        margin-bottom: .4rem;
    }

    .menu-card-desc {
        font-size: .8rem;
        color: #9a8878;
        line-height: 1.6;
        margin-bottom: 1.6rem;
        font-weight: 300;
    }

    .menu-card-foot {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding-top: 1.2rem;
        border-top: 1px solid var(--rule);
    }

    .menu-card-price {
        font-family: 'Playfair Display', serif;
        font-size: 1.25rem;
        font-weight: 700;
        color: var(--roast);
    }

    .menu-card-add {
        width: 34px;
        height: 34px;
        background: var(--roast);
        color: #fff;
        border: none;
        border-radius: 6px;
        font-size: 1.1rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background .2s;
    }

        .menu-card-add:hover {
            background: var(--amber);
        }

    /* ══════════════════════════════
           PERKS SECTION
        ══════════════════════════════ */
    .perks-section {
        background: var(--roast);
        padding: 6rem 5rem;
    }

    .perks-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 0;
        margin-top: 3.5rem;
        border: 1px solid rgba(255,255,255,.07);
        border-radius: 10px;
        overflow: hidden;
    }

    .perk {
        padding: 2.5rem 2rem;
        border-right: 1px solid rgba(255,255,255,.07);
        transition: background .25s;
    }

        .perk:last-child {
            border-right: none;
        }

        .perk:hover {
            background: rgba(255,255,255,.03);
        }

    .perk-icon {
        font-size: 1.8rem;
        margin-bottom: 1.2rem;
        display: block;
    }

    .perk-title {
        font-family: 'Playfair Display', serif;
        font-size: 1rem;
        font-weight: 700;
        color: var(--mist);
        margin-bottom: .5rem;
    }

    .perk-desc {
        font-size: .8rem;
        color: rgba(249,245,240,.4);
        line-height: 1.65;
        font-weight: 300;
    }

    /* ══════════════════════════════
           FOOTER
        ══════════════════════════════ */
    .footer {
        background: #0d0a06;
        padding: 3rem 5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 1.5rem;
        border-top: 1px solid rgba(255,255,255,.04);
    }

    .footer-logo {
        font-family: 'Playfair Display', serif;
        font-size: 1.2rem;
        font-weight: 900;
        color: var(--mist);
        text-decoration: none;
    }

        .footer-logo em {
            font-style: italic;
            color: var(--amber);
        }

    .footer-meta {
        font-size: .78rem;
        color: rgba(249,245,240,.3);
        display: flex;
        gap: 2rem;
    }

    /* ══════════════════════════════
           RESPONSIVE
        ══════════════════════════════ */
    @@media (max-width: 1024px) {
        .menu-grid {
            grid-template-columns: repeat(2, 1fr);
        }

        .perks-grid {
            grid-template-columns: repeat(2, 1fr);
        }

        .perk:nth-child(2) {
            border-right: none;
        }

        .perk:nth-child(3) {
            border-top: 1px solid rgba(255,255,255,.07);
        }

        .perk:nth-child(4) {
            border-top: 1px solid rgba(255,255,255,.07);
        }
    }

    @@media (max-width: 768px) {
        .nav {
            padding: 0 1.5rem;
        }

        .nav-links {
            display: none;
        }

        .hero {
            grid-template-columns: 1fr;
        }

        .hero-right {
            min-height: 50vh;
        }

        .hero-left {
            padding: 4rem 2rem 3rem;
        }

        .section, .perks-section {
            padding: 4rem 1.5rem;
        }

        .footer {
            padding: 2rem 1.5rem;
        }

        .menu-grid {
            grid-template-columns: 1fr;
        }

        .perks-grid {
            grid-template-columns: 1fr;
        }

        .perk {
            border-right: none;
            border-bottom: 1px solid rgba(255,255,255,.07);
        }
    }
</style>

