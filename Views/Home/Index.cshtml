    <!-- FOOTER -->
    <footer class="cf-footer">
        <div class="cf-footer-logo">Brew<span>&</span>Co</div>
        <p>📍 Near Campus · Open Mon–Sun · 6AM–9PM</p>
        <p>© 2025 Brew&Co Coffee Shop</p>
    </footer>

</div>