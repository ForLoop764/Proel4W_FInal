@{
    ViewData["Title"] = "Home Page";
}

<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">

<style>
    :root {
        --cream: #fdf6ec;
        --brown: #3b1f0e;
        --caramel: #c97d3a;
        --latte: #e8c99a;
        --foam: #faf0e0;
        --dark: #1a0f05;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
        background: var(--cream);
        font-family: 'DM Sans', sans-serif;
        color: var(--brown);
        overflow-x: hidden;
    }

    /* ✅ BREAK OUT OF BOOTSTRAP CONTAINER */
    .container, .container-fluid, .container-lg,
    .container-md, .container-sm, .container-xl {
        max-width: 100% !important;
        padding: 0 !important;
        margin: 0 !important;
    }

    /* ✅ FULL WIDTH WRAPPER */
    .cf-fullwidth {
        width: 100vw;
        position: relative;
        left: 50%;
        right: 50%;
        margin-left: -50vw;
        margin-right: -50vw;
    }

    /* HERO */
    .cf-hero {
        display: grid;
        grid-template-columns: 1fr 1fr;
        min-height: 100vh;
        overflow: hidden;
    }

    .cf-hero-left {
        background: var(--brown);
        display: flex;
        flex-direction: column;
        justify-content: center;
        padding: 6rem 5rem;
        position: relative;
        overflow: hidden;
        animation: slideInLeft 0.8s ease forwards;
    }

    @@keyframes slideInLeft {
        from { opacity: 0; transform: translateX(-40px); }
        to { opacity: 1; transform: translateX(0); }
    }

    @@keyframes slideInRight {
        from { opacity: 0; transform: translateX(40px); }
        to { opacity: 1; transform: translateX(0); }
    }

    @@keyframes float {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-15px); }
    }

    @@keyframes floatTag {
        0%, 100% { transform: translateY(0) rotate(-1deg); }
        50% { transform: translateY(-8px) rotate(1deg); }
    }

    @@keyframes fadeUp {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .cf-hero-left::before {
        content: '☕';
        font-size: 22rem;
        position: absolute;
        bottom: -4rem;
        right: -3rem;
        opacity: 0.05;
        line-height: 1;
    }

    .cf-badge {
        display: inline-block;
        background: var(--caramel);
        color: white;
        font-size: 0.72rem;
        font-weight: 600;
        letter-spacing: 2px;
        text-transform: uppercase;
        padding: 0.35rem 1rem;
        border-radius: 50px;
        margin-bottom: 1.5rem;
        width: fit-content;
        animation: fadeUp 0.6s 0.2s ease both;
    }

    .cf-hero-title {
        font-family: 'Syne', sans-serif;
        font-size: clamp(3rem, 5.5vw, 5rem);
        font-weight: 800;
        color: var(--foam);
        line-height: 1.05;
        margin-bottom: 1.5rem;
        animation: fadeUp 0.6s 0.3s ease both;
    }

    .cf-hero-title em {
        font-style: normal;
        color: var(--caramel);
    }

    .cf-hero-sub {
        color: var(--latte);
        font-size: 1.05rem;
        line-height: 1.7;
        max-width: 400px;
        margin-bottom: 2.5rem;
        opacity: 0.85;
        animation: fadeUp 0.6s 0.4s ease both;
    }

    .cf-hero-btns {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
        animation: fadeUp 0.6s 0.5s ease both;
    }

    .btn-primary {
        background: var(--caramel);
        color: white;
        border: none;
        padding: 1rem 2.2rem;
        border-radius: 50px;
        font-family: 'DM Sans', sans-serif;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        transition: transform 0.2s, box-shadow 0.2s;
        text-decoration: none;
        display: inline-block;
    }

    .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(201,125,58,0.4);
        color: white;
    }

    .btn-outline {
        background: transparent;
        color: var(--latte);
        border: 1.5px solid rgba(232,201,154,0.4);
        padding: 1rem 2.2rem;
        border-radius: 50px;
        font-family: 'DM Sans', sans-serif;
        font-size: 1rem;
        font-weight: 500;
        cursor: pointer;
        transition: border-color 0.2s, color 0.2s;
        text-decoration: none;
        display: inline-block;
    }

    .btn-outline:hover { border-color: var(--latte); color: var(--foam); }

    .cf-stats {
        display: flex;
        gap: 2.5rem;
        margin-top: 3.5rem;
        padding-top: 2rem;
        border-top: 1px solid rgba(232,201,154,0.15);
        animation: fadeUp 0.6s 0.6s ease both;
    }

    .cf-stat-num {
        font-family: 'Syne', sans-serif;
        font-size: 1.8rem;
        font-weight: 800;
        color: var(--caramel);
    }

    .cf-stat-label {
        font-size: 0.78rem;
        color: var(--latte);
        opacity: 0.7;
        margin-top: 0.1rem;
    }

    .cf-hero-right {
        background: var(--foam);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 3rem;
        position: relative;
        overflow: hidden;
        animation: slideInRight 0.8s ease forwards;
    }

    .cf-hero-right::before {
        content: '';
        position: absolute;
        width: 600px;
        height: 600px;
        background: radial-gradient(circle, rgba(201,125,58,0.12) 0%, transparent 70%);
        border-radius: 50%;
    }

    .cf-cup-visual {
        position: relative;
        z-index: 2;
        text-align: center;
    }

    .cf-cup-emoji {
        font-size: 13rem;
        display: block;
        animation: float 3s ease-in-out infinite;
        filter: drop-shadow(0 20px 40px rgba(59,31,14,0.2));
    }

    .cf-floating-tags {
        position: absolute;
        width: 100%;
        height: 100%;
        top: 0; left: 0;
    }

    .cf-tag {
        position: absolute;
        background: white;
        border-radius: 12px;
        padding: 0.7rem 1.2rem;
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--brown);
        box-shadow: 0 4px 20px rgba(59,31,14,0.1);
        white-space: nowrap;
        animation: floatTag 4s ease-in-out infinite;
    }

    .cf-tag:nth-child(1) { top: 15%; left: 5%; animation-delay: 0s; }
    .cf-tag:nth-child(2) { top: 20%; right: 5%; animation-delay: 1s; }
    .cf-tag:nth-child(3) { bottom: 25%; left: 8%; animation-delay: 2s; }
    .cf-tag:nth-child(4) { bottom: 20%; right: 8%; animation-delay: 0.5s; }

    /* MENU */
    .cf-menu {
        padding: 5rem 3rem;
        background: var(--cream);
    }

    .cf-section-header { text-align: center; margin-bottom: 3rem; }

    .cf-section-label {
        font-size: 0.75rem;
        letter-spacing: 3px;
        text-transform: uppercase;
        color: var(--caramel);
        font-weight: 600;
        margin-bottom: 0.8rem;
    }

    .cf-section-title {
        font-family: 'Syne', sans-serif;
        font-size: clamp(2rem, 4vw, 3rem);
        font-weight: 800;
        color: var(--brown);
        line-height: 1.1;
    }

    .cf-menu-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
        gap: 1.5rem;
        max-width: 1100px;
        margin: 0 auto;
    }

    .cf-menu-card {
        background: white;
        border-radius: 20px;
        padding: 1.8rem;
        transition: transform 0.3s, box-shadow 0.3s;
        border: 1px solid rgba(59,31,14,0.06);
        position: relative;
        overflow: hidden;
        cursor: pointer;
    }

    .cf-menu-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 20px 50px rgba(59,31,14,0.12);
    }

    .cf-menu-card::after {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 3px;
        background: var(--caramel);
        transform: scaleX(0);
        transition: transform 0.3s;
        transform-origin: left;
    }

    .cf-menu-card:hover::after { transform: scaleX(1); }

    .cf-card-icon { font-size: 2.5rem; margin-bottom: 1rem; }

    .cf-card-tag {
        display: inline-block;
        font-size: 0.65rem;
        font-weight: 700;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        padding: 0.25rem 0.7rem;
        border-radius: 50px;
        margin-bottom: 0.8rem;
        background: rgba(201,125,58,0.12);
        color: var(--caramel);
    }

    .cf-card-name {
        font-family: 'Syne', sans-serif;
        font-size: 1.2rem;
        font-weight: 700;
        color: var(--brown);
        margin-bottom: 0.4rem;
    }

    .cf-card-desc { font-size: 0.82rem; color: #7a6050; line-height: 1.6; margin-bottom: 1.2rem; }

    .cf-card-footer { display: flex; justify-content: space-between; align-items: center; }

    .cf-card-price {
        font-family: 'Syne', sans-serif;
        font-size: 1.3rem;
        font-weight: 800;
        color: var(--caramel);
    }

    .cf-card-btn {
        background: var(--brown);
        color: white;
        border: none;
        width: 36px; height: 36px;
        border-radius: 50%;
        font-size: 1.2rem;
        cursor: pointer;
        transition: background 0.2s, transform 0.2s;
        display: flex; align-items: center; justify-content: center;
    }

    .cf-card-btn:hover { background: var(--caramel); transform: scale(1.1); }

    /* PERKS */
    .cf-perks {
        background: var(--brown);
        padding: 4rem 3rem;
        text-align: center;
    }

    .cf-perks-title {
        font-family: 'Syne', sans-serif;
        font-size: clamp(1.8rem, 3vw, 2.5rem);
        font-weight: 800;
        color: var(--foam);
        margin-bottom: 0.5rem;
    }

    .cf-perks-sub { color: var(--latte); opacity: 0.75; margin-bottom: 3rem; font-size: 0.95rem; }

    .cf-perks-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 1.5rem;
        max-width: 900px;
        margin: 0 auto;
    }

    .cf-perk-card {
        background: rgba(255,255,255,0.05);
        border: 1px solid rgba(232,201,154,0.15);
        border-radius: 16px;
        padding: 2rem 1.5rem;
        transition: background 0.3s, transform 0.3s;
    }

    .cf-perk-card:hover { background: rgba(255,255,255,0.09); transform: translateY(-3px); }

    .cf-perk-icon { font-size: 2.2rem; margin-bottom: 1rem; }

    .cf-perk-name {
        font-family: 'Syne', sans-serif;
        font-weight: 700;
        font-size: 1rem;
        color: var(--latte);
        margin-bottom: 0.4rem;
    }

    .cf-perk-desc { font-size: 0.8rem; color: var(--latte); opacity: 0.6; line-height: 1.5; }

    /* FOOTER */
    .cf-footer {
        background: var(--dark);
        color: var(--latte);
        padding: 2rem 3rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1rem;
    }

    .cf-footer-logo {
        font-family: 'Syne', sans-serif;
        font-weight: 800;
        font-size: 1.2rem;
        color: var(--latte);
    }

    .cf-footer-logo span { color: var(--caramel); }
    .cf-footer p { font-size: 0.8rem; opacity: 0.5; }

    @@media (max-width: 768px) {
        .cf-hero { grid-template-columns: 1fr; }
        .cf-hero-right { min-height: 50vh; }
        .cf-hero-left { padding: 4rem 2rem; }
        .cf-menu, .cf-perks { padding: 3rem 1.5rem; }
    }
</style>

<!-- FULL WIDTH WRAPPER -->
<div class="cf-fullwidth">

    <!-- HERO -->
    <section class="cf-hero">
        <div class="cf-hero-left">
            <span class="cf-badge">☕ Now Open Near Campus</span>
